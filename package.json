{
  "name": "@vlbog/paperclip-plugin-workflow-studio",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Visual workflow editor that publishes Paperclip Company Skills",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "pack:check": "npm pack --dry-run",
    "prepack": "pnpm build",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "workspace"
  ],
  "author": "NoHum",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vladick-Pick/paperclip-plugin-workflow-studio.git"
  },
  "homepage": "https://github.com/Vladick-Pick/paperclip-plugin-workflow-studio",
  "bugs": {
    "url": "https://github.com/Vladick-Pick/paperclip-plugin-workflow-studio/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@paperclipai/shared": "2026.416.0",
    "@paperclipai/plugin-sdk": "2026.416.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
